# ============================================================
# Smart DevOps — Environment Variables Template
# Copy to .env and fill in your values.
# NEVER commit .env to source control.
# In production, inject via Jenkins Credentials Binding.
# ============================================================

# ---- Jira Data Center ----------------------------------------
JIRA_BASE_URL=https://jira.company.com
JIRA_API_TOKEN=your-jira-personal-access-token
JIRA_USERNAME=svc-smartdevops

# ---- Bitbucket Data Center -----------------------------------
BITBUCKET_BASE_URL=https://bitbucket.company.com
BITBUCKET_API_TOKEN=your-bitbucket-http-access-token
BITBUCKET_USERNAME=svc-smartdevops

# ---- Jenkins -------------------------------------------------
JENKINS_BASE_URL=https://jenkins.company.com
JENKINS_USERNAME=svc-smartdevops
JENKINS_API_TOKEN=your-jenkins-api-token

# ---- SonarQube -----------------------------------------------
SONAR_BASE_URL=https://sonarqube.company.com
SONAR_API_TOKEN=your-sonarqube-user-token

# ---- Nexus Repository Manager 3 -----------------------------
NEXUS_BASE_URL=https://nexus.company.com
NEXUS_USERNAME=svc-smartdevops
NEXUS_PASSWORD=your-nexus-password-or-token
# Docker registry endpoint (hostname:port of Nexus Docker hosted repo)
NEXUS_DOCKER_HOST=nexus.company.com:5000
NEXUS_DOCKER_REPO=docker-hosted

# ---- Coverity Connect ----------------------------------------
COVERITY_BASE_URL=https://coverity.company.com
COVERITY_USERNAME=svc-smartdevops
COVERITY_API_TOKEN=your-coverity-api-token

# ---- Black Duck ----------------------------------------------
BLACKDUCK_BASE_URL=https://blackduck.company.com
BLACKDUCK_API_TOKEN=your-blackduck-api-token

# ---- OpenShift (populated per environment by Deployer agent) -
OPENSHIFT_API_URL=https://api.openshift.company.com:6443
OPENSHIFT_TOKEN=your-openshift-service-account-token
OPENSHIFT_NAMESPACE_SIT=myapp-sit
OPENSHIFT_NAMESPACE_UAT=myapp-uat
OPENSHIFT_NAMESPACE_PROD=myapp-prod
OPENSHIFT_NAMESPACE_DR=myapp-dr

# ---- Pipeline state storage ----------------------------------
SMART_DEVOPS_STATE_DIR=/opt/smart-devops/state
